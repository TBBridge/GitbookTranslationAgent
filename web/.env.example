# Required on Vercel
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
ADMIN_PASSWORD_HASH=$argon2id$v=19$m=...
WORKER_TOKEN=replace_with_a_random_worker_token

# Optional: additional worker tokens for multiple workers.
# Comma-separated list or a JSON array/map; applied in addition to WORKER_TOKEN.
# WORKER_TOKENS=token-a,token-b

# Required for local/e2e database tests only when running against Neon
TEST_DATABASE_URL=postgresql://user:password@host/test_database?sslmode=require

# Optional local-only E2E mode; never enable in production
E2E_IN_MEMORY=0
